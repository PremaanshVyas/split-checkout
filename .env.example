# Airwallex sandbox credentials
# Get these from the Airwallex sandbox web app:
#   https://demo.airwallex.com → Developer → API Keys
# Sandbox credentials are still secrets — never commit the real .env.
AIRWALLEX_CLIENT_ID=your_client_id_here
AIRWALLEX_API_KEY=your_api_key_here

# Airwallex sandbox API base URL (do not change for the demo)
AIRWALLEX_BASE_URL=https://api-demo.airwallex.com

# Server
PORT=3001

# Webhook signing secret (optional — only needed for the webhook listener,
# from https://demo.airwallex.com → Developer → Webhooks)
# AIRWALLEX_WEBHOOK_SECRET=
